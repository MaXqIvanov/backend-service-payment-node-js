{
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"moduleDetection": "force",
		"lib": ["ES2022"],
		"types": ["node", "jest"],
		"rootDir": "./src",
		"outDir": "./dist",
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true
	},

	"include": ["src/**/*"]
}
